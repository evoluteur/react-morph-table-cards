{
  "name": "react-morph-table-cards",
  "version": "0.1.0",
  "description": "A reusable React/TypeScript component that morphs between table and card views with animated transitions on sort, view toggle, and resize.",
  "type": "module",
  "main": "./dist/react-morph-table-cards.cjs",
  "module": "./dist/react-morph-table-cards.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-morph-table-cards.js",
      "require": "./dist/react-morph-table-cards.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "keywords": [
    "react",
    "typescript",
    "morphing",
    "table",
    "cards",
    "list",
    "view-toggle",
    "animation",
    "transition",
    "layout",
    "component"
  ],
  "author": "Olivier Giulieri (https://evoluteur.github.io/)",
  "copyright": "(c) 2026 Olivier Giulieri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evoluteur/react-morph-table-cards.git"
  },
  "homepage": "https://evoluteur.github.io/react-morph-table-cards",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.1.0"
  }
}
